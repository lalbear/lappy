# Lappy AI — Environment Variables Template
# Copy this file to .env and fill in your keys
# DO NOT commit .env — it contains secrets

# OpenRouter API Key (get one free at https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY=

# Set to "true" to allow using the key above as a fallback when user hasn't added their own
VITE_FREE_MODE_ENABLED=true
