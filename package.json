{
  "name": "lappy",
  "version": "1.0.0",
  "description": "Floating AI assistant for your desktop",
  "private": true,
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev":      "npm run dev:desktop",
    "dev:web":  "vite",
    "dev:desktop": "sh -c 'vite --port 5174 --strictPort & VITE_PID=$!; sleep 2; electron .; kill $VITE_PID'",
    "electron": "NODE_ENV=development electron .",
    "build":    "vite build",
    "build:desktop": "npm run build",
    "preview":  "vite preview",
    "pack":     "npm run build:desktop && electron-builder"
  },
  "devDependencies": {
    "electron":             "^41.3.0",
    "electron-builder":     "^26.8.1",
    "vite":                 "^8.0.10",
    "vite-plugin-electron": "^0.29.1"
  },
  "build": {
    "appId":       "com.lappy.app",
    "productName": "Lappy",
    "mac": {
      "category": "public.app-category.productivity",
      "target":   "dmg",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
